# 複製本檔為 .env 並填入實際值,.env 不可進版控

# --- LINE Messaging API ---
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# --- Google OAuth 2.0 client(供親友連結個人 Google Sheets/Drive 用) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/oauth/callback

# --- Google Cloud Firestore(系統中繼資料,僅存連結關係) ---
# 本機 Docker:用檔案路徑(docker-compose 掛 volume 進容器)
GOOGLE_APPLICATION_CREDENTIALS=/secrets/firestore-service-account.json

# Render 部署:免費方案無持久化磁碟可掛密鑰檔,改貼整份 service account JSON 字串到這個變數,
# app/db/firestore_client.py 啟動時判斷:有 GOOGLE_APPLICATION_CREDENTIALS 檔案路徑就用檔案,
# 沒有就改用這個變數的 JSON 字串(json.loads 後傳給 google.oauth2.service_account.Credentials.from_service_account_info)
FIRESTORE_SERVICE_ACCOUNT_JSON=
FIRESTORE_PROJECT_ID=

# --- 加密金鑰(cryptography.fernet,用於加密儲存 refresh token) ---
ENCRYPTION_KEY=

# --- 管理員 ---
ADMIN_LINE_USER_ID=

# --- 應用程式 ---
PORT=8000
TZ=Asia/Taipei
