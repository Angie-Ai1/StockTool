# 複製本檔為 .env 並填入實際值,.env 不可進版控

# --- LINE Messaging API ---
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# --- Google OAuth 2.0 client(供親友連結個人 Google Sheets/Drive 用) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/oauth/callback
# 範本試算表的 Google Drive 檔案 ID(規格 3.1,內含分頁結構/資料驗證/版本號標記,
# 需手動在 Drive 建立一次後填入,本機/Cloud Run 共用同一個範本)
GOOGLE_SHEETS_TEMPLATE_ID=

# --- Google Cloud Firestore(系統中繼資料,僅存連結關係) ---
# 本機 Docker:docker-compose 把 secrets/firestore-service-account.json 掛 volume 進容器這個路徑。
# Cloud Run 部署:同一個路徑改由 Secret Manager 把密鑰「掛載為磁碟區(Mount as volume)」提供,
# 不再用一般環境變數貼 JSON 內容(理由與設定步驟見 Instruction/cloud_setting.md 第 4.2 節)。
# 兩邊殊途同歸都是同一個檔案路徑,app/db/firestore_client.py 不需要分本機/雲端兩套邏輯。
GOOGLE_APPLICATION_CREDENTIALS=/secrets/firestore-service-account.json
FIRESTORE_PROJECT_ID=

# --- 加密金鑰(cryptography.fernet,用於加密儲存 refresh token) ---
ENCRYPTION_KEY=

# --- 管理員 ---
ADMIN_LINE_USER_ID=

# --- 應用程式 ---
# 本機/Docker 開發用,Cloud Run 上 PORT 是保留變數,由平台自動注入,不要手動設定
PORT=8000
TZ=Asia/Taipei
